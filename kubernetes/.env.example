# Versões de referência atuais em julho de 2026.
KUBERNETES_MINOR="v1.36"
POD_NETWORK_CIDR="10.244.0.0/16"
SERVICE_CIDR="10.96.0.0/12"

# Deixe vazio para detectar o IPv4 da rota padrão.
NODE_IP=""
NODE_NAME=""

# Usuário Linux que receberá ~/.kube/config. Quando vazio, usa SUDO_USER
# ou cria o usuário k8sadmin se o instalador for chamado diretamente por root.
ADMIN_USER=""
ADMIN_GROUP="k8s-operators"
SINGLE_NODE="true"

# Dashboard Web (Headlamp). NodePort precisa estar entre 30000 e 32767.
DASHBOARD_NAMESPACE="kubernetes-dashboard"
DASHBOARD_NODE_PORT="30443"
DASHBOARD_ALLOWED_CIDR="0.0.0.0/0"
DASHBOARD_DNS_NAME=""
DASHBOARD_PUBLIC_IP=""
DASHBOARD_CERT_DAYS="825"
HEADLAMP_IMAGE="ghcr.io/headlamp-k8s/headlamp:v0.43.0"
DASHBOARD_ROLLOUT_TIMEOUT="10m"

# Perfis de login do Dashboard.
CREATE_ADMIN_SERVICE_ACCOUNT="true"
DEFAULT_TOKEN_DURATION="8h"

# Rede e firewall do host.
FLANNEL_VERSION="v0.28.4"
FLANNEL_SHA256="d078019743c5e0194ce965125fc80ef00af0c1661ec9e12396311f1cfec860a2"
ENABLE_UFW="true"
SSH_PORT="22"

# Use true somente para testes em outra versão do Ubuntu.
ALLOW_UNSUPPORTED_OS="false"
